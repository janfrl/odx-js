{
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "destination": "odx-proxy-backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false,
      "forwardAuthToken": true
    },
    {
      "source": "^/(.*)$",
      "target": "/$1",
      "destination": "odx-explorer-ui",
      "authenticationType": "xsuaa"
    }
  ]
}
