<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0" xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">
  <edmx:DataServices>
    <Schema Namespace="TestService" xmlns="http://schemas.microsoft.com/ado/2008/09/edm">
      <EntityType Name="TestItem">
        <Key>
          <PropertyRef Name="ID" />
        </Key>
        <Property Name="ID" Type="Edm.String" Nullable="false" />
        <Property Name="Title" Type="Edm.String" />
        <Property Name="Value" Type="Edm.Int32" />
      </EntityType>
      <EntityContainer Name="TestContainer">
        <EntitySet Name="TestItems" EntityType="TestService.TestItem" />
      </EntityContainer>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
