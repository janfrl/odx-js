{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@me-tools/odx-metadata": ["./packages/metadata/src/index.ts"],
      "@me-tools/odx-core": ["./packages/core/src/index.ts"],
      "@me-tools/odx-core/server": ["./packages/core/src/server.ts"],
      "@me-tools/odx-proxy": ["./packages/proxy/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "dist",
    "packages/*/dist",
    "node_modules",
    "playground",
    "docs",
    "packages/explorer"
  ]
}
