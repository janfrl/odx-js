{
  "xsappname": "odx_fullstack_v2",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.user_attributes",
      "description": "User Attributes"
    }
  ],
  "attributes": [
    {
      "name": "employee_id",
      "description": "ID of employee",
      "valueType": "s"
    },
    {
      "name": "company_id",
      "description": "ID of company",
      "valueType": "s"
    }
  ],
  "role-templates": [
    {
      "name": "Token_Exchange",
      "description": "Can perform token exchange",
      "scope-references": [
        "uaa.user"
      ]
    },
    {
      "name": "odx_user",
      "description": "Standard ODX User",
      "scope-references": [
        "$XSAPPNAME.user_attributes"
      ],
      "attribute-references": [
        "employee_id",
        "company_id"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.hana.ondemand.com/**",
      "https://*.cfapps.*.hana.ondemand.com/**",
      "https://*.applicationstudio.cloud.sap/**"
    ]
  }
}
