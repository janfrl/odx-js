{
  "name": "@bc8-odx/nuxt",
  "type": "module",
  "version": "0.0.1",
  "exports": {
    ".": "./src/module.ts",
    "./generate": "./src/generate.ts"
  },
  "main": "./src/module.ts",
  "scripts": {
    "dev": "nuxi dev test/fixtures/isolated",
    "playground:check": "nuxi prepare playground/minimal && node playground/minimal/verify.mjs",
    "prepare": "nuxt-module-build prepare && nuxi prepare test/fixtures/isolated",
    "test": "vitest run",
    "verify": "vitest run test/devtools.test.ts test/generate.test.ts test/isolated.test.ts test/module.test.ts && pnpm run playground:check"
  },
  "dependencies": {
    "@bc8-odx/core": "workspace:*",
    "@bc8-odx/proxy": "workspace:*",
    "@odata2ts/odata2ts": "^0.40.1"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "nuxt": "^4.4.2",
    "playwright-core": "^1.58.2",
    "vitest": "^4.1.1"
  }
}
