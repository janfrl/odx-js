{
  "name": "@bc8-odx/nuxt",
  "type": "module",
  "version": "0.0.1",
  "private": false,
  "description": "Nuxt module for type-safe OData access, SDK generation, proxying, and DevTools integration.",
  "license": "MIT",
  "homepage": "https://github.com/janfrl/odx-js#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/janfrl/odx-js.git"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs",
      "default": "./dist/module.mjs"
    },
    "./generate": {
      "types": "./dist/generate.d.mts",
      "import": "./dist/generate.mjs",
      "default": "./dist/generate.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "generate": [
        "./dist/generate.d.mts"
      ]
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "nuxi dev test/fixtures/isolated",
    "playground:check": "nuxi prepare playground/minimal && node playground/minimal/verify.mjs",
    "prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare test/fixtures/isolated",
    "test": "vitest run",
    "verify": "vitest run && pnpm run playground:check",
    "build": "nuxt-module-build build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "pnpm run build && pnpm run verify",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare"
  },
  "dependencies": {
    "@bc8-odx/core": "workspace:*",
    "@bc8-odx/explorer": "workspace:*",
    "@bc8-odx/proxy": "workspace:*",
    "@nuxt/devtools-kit": "3.2.4",
    "@nuxt/kit": "4.4.8",
    "@nuxt/schema": "4.4.8",
    "@odata2ts/odata2ts": "^0.40.1",
    "consola": "3.4.2",
    "h3": "1.15.11",
    "nitropack": "2.13.4",
    "pathe": "2.0.3",
    "sirv": "3.0.2"
  },
  "devDependencies": {
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "^26.1.1",
    "nuxt": "^4.4.8",
    "playwright-core": "^1.58.2",
    "tsx": "4.21.0",
    "typescript": "~5.9.3",
    "unbuild": "3.6.1",
    "vitest": "4.1.3"
  }
}
