{
  "fetchRealXsuaaToken": {
    "title": "fetchRealXsuaaToken",
    "description": "Fetches a real JWT token from SAP BTP XSUAA using Password Grant.\nUsed for local testing with real user data.",
    "properties": [
      {
        "name": "credentials",
        "type": "{ clientid: string; clientsecret: string; url: string; }",
        "required": true
      },
      {
        "name": "user",
        "type": "string",
        "required": true
      },
      {
        "name": "pass",
        "type": "string",
        "required": true
      }
    ]
  },
  "parseXsuaaPolicies": {
    "title": "parseXsuaaPolicies",
