        "required": false
      },
      {
        "name": "rejectUnauthorized",
        "type": "boolean | undefined",
        "description": "Whether to reject unauthorized TLS certificates.",
        "default": "true",
        "required": false
      },
      {
        "name": "forwardAuthHeader",
        "type": "boolean | undefined",
        "description": "Whether to forward the Authorization header to the OData backend.",
        "default": "true",
        "required": false
      },
      {
        "name": "services",
        "type": "ODataServiceConfig[] | undefined",
        "description": "List of OData services to configure.",
        "default": "[]",
        "required": false
      },
      {
        "name": "buildDir",
        "type": "string | undefined",
        "required": false
      },
      {
        "name": "rootDir",
        "type": "string | undefined",
        "required": false
      },
      {
        "name": "btpConfigService",
        "type": "string | undefined",
        "required": false
      },
      {
        "name": "devtools",
        "type": "{ enabled?: boolean; maxLogs?: number; logPayloads?: boolean; maxPayloadBytes?: number; logStore?: OdxRuntimeLogStoreConfig; } | undefined",
        "required": false
      }
    ]
  }
}
