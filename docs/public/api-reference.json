  "$odata": {
    "title": "$odata",
    "description": "Low-level OData utility.\nExecutes a single OData request using the provided client.",
    "properties": [
      {
        "name": "client",
        "type": "<R>(path: string, options?: any) => Promise<R>",
        "required": true
      },
      {
        "name": "service",
        "type": "string",
        "required": true
      },
      {
        "name": "method",
        "type": "\"GET\" | \"POST\" | \"PATCH\" | \"DELETE\"",
        "default": "'GET'",
        "required": false
      },
      {
        "name": "options",
        "type": "FetchOptions<\"json\", any> & { entitySet?: string; }",
        "default": "{}",
        "required": false
      }
    ]
  },
