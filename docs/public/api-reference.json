  "ODataAsyncData": {
    "title": "ODataAsyncData",
    "description": "Minimal interface mimicking Nuxt's AsyncData for type inference.\nThe intersection with the raw type T helps the Vue template compiler\nand IDE to see the unwrapped types without a direct Vue dependency.",
    "properties": [
      {
        "name": "data",
        "type": "{ value: T | null; } & T",
        "description": "Reactive data payload.",
        "default": "null",
        "required": true
      },
      {
        "name": "pending",
        "type": "{ value: boolean; } & boolean",
        "description": "Boolean state indicating if the request is in-flight.",
        "default": "false",
        "required": true
      },
      {
        "name": "error",
        "type": "any",
        "description": "Error object if the request failed.",
        "default": "null",
        "required": true
      },
      {
        "name": "status",
        "type": "{ value: \"idle\" | \"pending\" | \"success\" | \"error\"; } & (\"success\" | \"error\" | \"idle\" | \"pending\")",
        "description": "Status of the request: idle, pending, success, or error.",
        "default": "'idle'",
        "required": true
      },
      {
        "name": "refresh",
        "type": "(opts?: any) => Promise<void>",
        "description": "Function to manually refresh the data.",
        "required": true
      },
      {
        "name": "execute",
        "type": "(opts?: any) => Promise<void>",
        "description": "Function to execute the request.",
        "required": true
      },
      {
        "name": "clear",
        "type": "() => void",
        "description": "Function to clear the data and error states.",
        "required": true
      }
    ]
  },
  "ODataQuery": {
    "title": "ODataQuery",
    "description": "Structured OData query options.\nT: The model type of the entity being queried.",
    "properties": [
