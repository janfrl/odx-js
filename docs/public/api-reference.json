  "parseCsdl": {
    "title": "parseCsdl",
    "description": "Parses XML or JSON CSDL without I/O. For ambiguous input, pass format\nexplicitly. JSON text must have an object root.",
    "properties": [
      {
        "name": "input",
        "type": "string | number | boolean | CsdlJsonInput[] | { [key: string]: CsdlJsonInput; } | null",
        "required": true
      },
