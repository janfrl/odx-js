        "name": "$search",
        "type": "string | undefined",
        "description": "Search expression (OData V4).",
        "required": false
      }
    ]
  },
  "ODataEntitySet": {
    "title": "ODataEntitySet",
    "description": "Interface for a specific OData Entity Set.\nT: The model type of the entity.",
