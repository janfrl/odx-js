# Default OData proxy destination
NUXT_ODATA_DESTINATION=https://your-sap-system.com/sap/opu/odata/sap/

# Service definition (Pattern: NUXT_ODATA_SERVICES_<KEY>_URL)
# Optional: SDK Name (Pattern: NUXT_ODATA_SERVICES_<KEY>_NAME)
# Optional: Explorer Icon (Pattern: NUXT_ODATA_SERVICES_<KEY>_ICON)
NUXT_ODATA_SERVICES_MYSERVICE_NAME=MyService
NUXT_ODATA_SERVICES_MYSERVICE_URL=https://your-sap-system.com/sap/opu/odata/sap/API_BUSINESS_PARTNER
NUXT_ODATA_SERVICES_MYSERVICE_ICON=i-lucide-users

# Forward authorization headers (true/false)
NUXT_ODATA_FORWARD_AUTH_HEADER=true

# Base path for the OData proxy
NUXT_ODATA_BASE_PATH=/api/sap-odata

# Module runtime mode (default: sdk)
NUXT_ODATA_MODE=sdk
