{
  "name": "nuxt-sap-odata",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.0",
  "description": "My new Nuxt module",
  "license": "MIT",
  "repository": "Bechtle-AG/nuxt-sap-odata",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nr dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "nr lint && nr test && nr prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/devtools-kit": "^3.2.1",
    "@nuxt/kit": "^4.3.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "fast-xml-parser": "^5.0.0",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@antfu/ni": "^28.2.0",
    "@iconify-json/carbon": "^1.2.18",
    "@nuxt/devtools": "^3.2.1",
    "@nuxt/devtools-ui-kit": "^3.2.1",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/eslint-config": "^1.15.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@sap-cloud-sdk/generator": "^4.4.0",
    "@types/dagre": "^0.7.52",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "eslint": "^10.0.0",
    "nuxt": "^4.3.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
