{
  "name": "odx",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "description": "ODX: OData Developer Experience - A modern toolkit for SAP OData integration",
  "license": "MIT",
  "repository": "janfrl/odx-js",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @bc8-odx/explorer build && pnpm --filter @bc8-odx/proxy build && shx cp -f packages/explorer/.output/server/package.json packages/explorer/.output/package.json && shx cp -f packages/proxy/.output/server/package.json packages/proxy/.output/package.json && mbt build -t mta_archives --mtar odx-fullstack.mtar",
    "deploy": "cf deploy mta_archives/odx-fullstack.mtar",
    "dev": "nr dev:prepare && nuxi dev playground",
    "dev:prepare": "pnpm exec nuxt-module-build build --stub && pnpm exec nuxt-module-build prepare && nuxi prepare playground && nuxi prepare packages/explorer && nuxi prepare docs",
    "prepack": "pnpm exec nuxt-module-build build",
    "docs": "nuxi dev docs",
    "docs:prepare": "nuxi prepare docs",
    "docs:clean": "pnpm --filter docs clean",
    "release": "tsx scripts/release.ts",
    "bump": "tsx scripts/bump.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run packages/core packages/proxy packages/explorer",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nuxt/devtools-kit": "^3.2.4",
    "@nuxt/kit": "^4.4.2",
    "@vueuse/core": "^14.2.1",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@antfu/ni": "^30.0.0",
    "@iconify-json/carbon": "^1.2.19",
    "@iconify-json/lucide": "^1.2.98",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@odata2ts/odata-service": "^0.23.1",
    "@sap-cloud-sdk/generator": "^4.5.1",
    "@sap-ux/fe-mockserver-core": "^1.7.10",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.3",
    "changelogen": "^0.6.2",
    "consola": "^3.4.2",
    "eslint": "^10.1.0",
    "happy-dom": "^20.8.8",
    "nuxt": "^4.4.2",
    "pathe": "^2.0.3",
    "shx": "^0.4.0",
    "tinyglobby": "^0.2.15",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.6"
  }
}
