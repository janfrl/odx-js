{
  "name": "odx",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.0",
  "description": "ODX: OData Developer Experience - A modern toolkit for SAP OData integration",
  "license": "MIT",
  "repository": "janfrl/odx-js",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -r prepack",
    "prepack": "nuxt-module-build build",
    "dev": "nr dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "build:proxy": "pnpm --filter @bc8-odx/proxy build",
    "build:mta": "mbt build --mtar archive.mtar",
    "deploy:mta": "cf deploy mta_archives/archive.mtar",
    "docs": "nuxi dev docs",
    "docs:prepare": "nuxi prepare docs",
    "release": "tsx scripts/release.ts",
    "bump": "tsx scripts/bump.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run packages/core packages/proxy packages/explorer",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/devtools-kit": "^3.2.1",
    "@nuxt/kit": "^4.3.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "dagre": "^0.8.5",
    "fast-xml-parser": "^5.0.0",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@antfu/ni": "^28.2.0",
    "@iconify-json/carbon": "^1.2.18",
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/devtools": "^3.2.1",
    "@nuxt/devtools-ui-kit": "^3.2.1",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/eslint-config": "^1.15.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@odata2ts/odata-service": "^0.23.1",
    "@sap-cloud-sdk/generator": "^4.4.0",
    "@sap-ux/fe-mockserver-core": "^1.7.8",
    "@types/dagre": "^0.7.52",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "consola": "^3.4.2",
    "eslint": "^10.0.0",
    "happy-dom": "^17.1.0",
    "nuxt": "^4.3.1",
    "pathe": "^2.0.3",
    "tinyglobby": "^0.2.15",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
